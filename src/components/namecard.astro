---
const { opacity, zindex } = Astro.props;
---

<style define:vars={{ opacity, zindex }}>
  .namecard {
    width: fit-content;
    height: fit-content;
    position: relative;
    z-index: var(--zindex);
  }

  .inner {
    font-size: 12px;
    transform: rotateX(0deg);
    transition: all 1s;
    backface-visibility: hidden;
    -webkit-box-shadow: 0px 9px 11px 6px rgba(0, 0, 0, var(--opacity));
    box-shadow: 0px 9px 11px 6px rgba(0, 0, 0, var(--opacity));
    z-index: var(--zindex);
    filter: brightness(calc(90% + (5% * var(--zindex)) / 10));
  }

  .namecard:hover .inner {
    transform: rotateX(180deg);
  }

  .front {
    transform: rotateX(0deg);
    position: relative;
  }

  .back {
    position: absolute;
    top: 0px;
    left: 0px;
    margin-top: 0%;
    transform: rotateX(180deg);
  }

  .namecard:hover .back {
    transform: rotateX(0deg);
  }
</style>

<div id="content-wrapper" class="namecard">
  <div class="sidebar inner front block" style="display: flex">
    <slot name="front" />
  </div>
  <div class="sidebar inner back block" style="display: flex">
    <slot name="back" />
  </div>
</div>
